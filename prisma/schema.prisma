generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum AccountStatus {
  PENDING_REGISTRATION
  PENDING_PAYMENT
  PAYMENT_PROCESSING
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
  BLOCKED
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  PAYMENT_PROCESSING
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum PlatformRole {
  OWNER
  SUPPORT
  OPERATIONS
  MAINTENANCE
}

enum PlatformPermission {
  USERS_WRITE
  COMPANIES_WRITE
  COURSES_WRITE
  PAYMENTS_READ
  SUPPORT_WRITE
  MAINTENANCE_WRITE
}

enum SupportTicketStatus {
  OPEN
  ASSIGNED
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SaleStatus {
  PAID
  REFUNDED
  CHARGEBACK
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum PlatformPayoutStatus {
  REQUESTED
  PROCESSING
  PAID
  FAILED
  CANCELED
}

enum LessonCompletionRequirement {
  VIDEO_WATCHED
  TASK_SUBMITTED
  MANUAL_CONFIRMATION
  ANY
}

enum EnrollmentPaymentStatus {
  FREE
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ContentVisibility {
  PUBLIC
  PRIVATE
}

enum CommunityAccessMode {
  PUBLIC
  INVITE_ONLY
  PASSWORD
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  subdomain String   @unique
  createdAt DateTime @default(now())

  users                   User[]
  courses                 Course[]
  modules                 Module[]
  lessons                 Lesson[]
  enrollments             Enrollment[]
  lessonProgress          LessonProgress[]
  certificates            Certificate[]
  supportTickets          SupportTicket[]
  courseSales             CourseSale[]
  paymentCheckouts        PaymentCheckout[]
  paymentWebhookEvents    PaymentWebhookEvent[]
  posts                   Post[]
  postComments            PostComment[]
  postReactions           PostReaction[]
  communities             Community[]
  communityMembers        CommunityMember[]
  communityMessages       CommunityMessage[]
  privateConversations    PrivateConversation[]
  privateMessages         PrivateMessage[]
  opportunities           Opportunity[]
  opportunityApplications OpportunityApplication[]
  benefits                Benefit[]
  benefitRedemptions      BenefitRedemption[]
  events                  Event[]
  eventRegistrations      EventRegistration[]
  userFollows             UserFollow[]
  friendRequests          FriendRequest[]
  socialNotifications     SocialNotification[]

  @@map("tenants")
}

model User {
  id                     String        @id @default(uuid()) @db.Uuid
  /// Email interno usado para login na plataforma, por exemplo nome.gmail@meetpoint.com.
  email                  String
  emailHash              String?
  emailEncrypted         String?
  /// Email real verificado do usuario. Usado para notificacoes, recuperacao de senha, vagas, eventos e cursos.
  contactEmailHash       String?
  contactEmailEncrypted  String?
  contactEmailVerifiedAt DateTime?
  /// Celular/WhatsApp real verificado. Usado para notificacoes e avisos operacionais.
  contactPhoneHash       String?
  contactPhoneEncrypted  String?
  contactPhoneVerifiedAt DateTime?
  password               String
  passwordHash           String?
  name                   String        @default("")
  city                   String        @default("")
  state                  String        @default("")
  profileImage           String?
  bio                    String?
  acceptedTerms          Boolean       @default(false)
  acceptedPrivacyPolicy  Boolean       @default(false)
  role                   UserRole      @default(USER)
  status                 AccountStatus @default(ACTIVE)
  tenantId               String        @db.Uuid
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  lastLoginAt            DateTime?
  lastActivityAt         DateTime?
  blockedAt              DateTime?
  blockedReason          String?
  lastLoginIpEncrypted   String?
  lastKnownGeoEncrypted  String?

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments             Enrollment[]
  lessonProgress          LessonProgress[]
  certificates            Certificate[]
  supportTickets          SupportTicket[]
  courseSales             CourseSale[]
  paymentCheckouts        PaymentCheckout[]
  paymentWebhookEvents    PaymentWebhookEvent[]
  termsConsents           TermsConsent[]
  privacyConsents         UserPrivacyConsent[]
  subscriptions           Subscription[]
  subscriptionAuditLogs   SubscriptionAuditLog[]
  posts                   Post[]
  postComments            PostComment[]
  postReactions           PostReaction[]
  ownedCommunities        Community[]
  communityMemberships    CommunityMember[]
  communityMessages       CommunityMessage[] @relation("CommunityMessageAuthor")
  deletedCommunityMessages CommunityMessage[] @relation("CommunityMessageDeletedBy")
  privateConversationsStarted PrivateConversation[] @relation("PrivateConversationFirstUser")
  privateConversationsReceived PrivateConversation[] @relation("PrivateConversationSecondUser")
  privateMessages         PrivateMessage[] @relation("PrivateMessageSender")
  opportunities           Opportunity[]
  opportunityApplications OpportunityApplication[]
  benefits                Benefit[]
  benefitRedemptions      BenefitRedemption[]
  events                  Event[]
  eventRegistrations      EventRegistration[]
  following               UserFollow[] @relation("UserFollowing")
  followers               UserFollow[] @relation("UserFollowers")
  sentFriendRequests      FriendRequest[] @relation("FriendRequestRequester")
  receivedFriendRequests  FriendRequest[] @relation("FriendRequestRecipient")
  socialNotifications     SocialNotification[] @relation("SocialNotificationRecipient")
  socialNotificationActor SocialNotification[] @relation("SocialNotificationActor")

  @@unique([tenantId, email])
  @@unique([tenantId, emailHash])
  @@unique([tenantId, contactEmailHash])
  @@unique([tenantId, contactPhoneHash])
  @@index([tenantId])
  @@index([emailHash])
  @@index([contactEmailHash])
  @@index([contactPhoneHash])
  @@index([status])
  @@index([lastActivityAt])
  @@map("users")
}

model TermsConsent {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  termsVersion String
  acceptedAt   DateTime @default(now())
  ip           String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([termsVersion])
  @@map("terms_consents")
}

model UserPrivacyConsent {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  termsVersion   String
  privacyVersion String
  consentType    String
  accepted       Boolean   @default(false)
  acceptedAt     DateTime?
  ipAddress      String?
  userAgent      String?
  country        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([termsVersion])
  @@index([privacyVersion])
  @@index([consentType])
  @@map("user_privacy_consents")
}

model SubscriptionPlan {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  price          Decimal  @db.Decimal(10, 2)
  billingCycle   String
  features       Json
  maxStorage     Int?
  maxUploads     Int?
  maxCommunities Int?
  maxMessages    Int?
  maxEvents      Int?
  maxCourses     Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive])
  @@index([billingCycle])
  @@map("subscription_plans")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  userId                 String             @db.Uuid
  planId                 String             @db.Uuid
  status                 SubscriptionStatus @default(PENDING_PAYMENT)
  paymentProvider        String?
  externalSubscriptionId String?
  checkoutAmountCents    Int?
  checkoutBillingCycle   String?
  transactionNsu         String?
  receiptUrl             String?
  startedAt              DateTime?
  expiresAt              DateTime?
  renewalDate            DateTime?
  cancelledAt            DateTime?
  paidAt                 DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan       @relation(fields: [planId], references: [id], onDelete: Restrict)
  auditLogs SubscriptionAuditLog[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([externalSubscriptionId])
  @@map("subscriptions")
}

model SubscriptionAuditLog {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  subscriptionId   String   @db.Uuid
  eventType        String
  oldStatus        String?
  newStatus        String?
  paymentReference String?
  createdAt        DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([eventType])
  @@index([createdAt])
  @@map("subscription_audit_logs")
}

model Course {
  id                String            @id @default(uuid()) @db.Uuid
  title             String
  topic             String?
  description       String?
  coverUrl          String?
  instructorName    String?
  publisherType     String?
  linkedCompanyName String?
  creatorUserId     String?           @db.Uuid
  priceCents        Int               @default(0)
  currency          String            @default("BRL")
  platformFeeBps    Int               @default(1000)
  visibility        ContentVisibility @default(PUBLIC)
  tenantId          String            @db.Uuid
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modules              Module[]
  enrollments          Enrollment[]
  certificates         Certificate[]
  sales                CourseSale[]
  paymentCheckouts     PaymentCheckout[]
  paymentWebhookEvents PaymentWebhookEvent[]

  @@index([tenantId])
  @@index([tenantId, topic])
  @@index([visibility, createdAt])
  @@map("courses")
}

model Post {
  id         String            @id @default(uuid()) @db.Uuid
  tenantId   String            @db.Uuid
  authorId   String            @db.Uuid
  sharedFromPostId String?     @db.Uuid
  visibility ContentVisibility @default(PUBLIC)
  body       String
  mediaUrl   String?
  mediaType  String?
  city       String?
  tag        String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sharedFrom Post?         @relation("PostShares", fields: [sharedFromPostId], references: [id], onDelete: SetNull)
  shares    Post[]         @relation("PostShares")
  comments  PostComment[]
  reactions PostReaction[]

  @@index([visibility, createdAt])
  @@index([tenantId, createdAt])
  @@index([authorId, createdAt])
  @@index([sharedFromPostId])
  @@map("posts")
}

model UserFollow {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  follower  User   @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User   @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([tenantId, createdAt])
  @@index([followingId, createdAt])
  @@map("user_follows")
}

model FriendRequest {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @db.Uuid
  requesterId String              @db.Uuid
  recipientId String              @db.Uuid
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  respondedAt DateTime?

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requester User   @relation("FriendRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User   @relation("FriendRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([tenantId, status, createdAt])
  @@index([recipientId, status, createdAt])
  @@index([requesterId, status, createdAt])
  @@map("friend_requests")
}

model SocialNotification {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  recipientId String   @db.Uuid
  actorId     String?  @db.Uuid
  type        String
  title       String
  read        Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipient User   @relation("SocialNotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User?  @relation("SocialNotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, read, createdAt])
  @@index([tenantId, createdAt])
  @@map("social_notifications")
}

model PostComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  tenantId  String   @db.Uuid
  authorId  String   @db.Uuid
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
  @@map("post_comments")
}

model PostReaction {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  type      String   @default("like")
  createdAt DateTime @default(now())

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, type])
  @@index([postId])
  @@index([userId])
  @@map("post_reactions")
}

model Community {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @db.Uuid
  ownerId     String            @db.Uuid
  visibility  ContentVisibility @default(PUBLIC)
  accessMode  CommunityAccessMode @default(PUBLIC)
  passwordHash String?
  inviteCodeHash String?
  name        String
  topic       String?
  description String?
  city        String?
  imageUrl    String?
  memberCount Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner   User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members CommunityMember[]
  messages CommunityMessage[]

  @@index([visibility, createdAt])
  @@index([tenantId, createdAt])
  @@index([ownerId, createdAt])
  @@map("communities")
}

model CommunityMember {
  id          String   @id @default(uuid()) @db.Uuid
  communityId String   @db.Uuid
  tenantId    String   @db.Uuid
  userId      String   @db.Uuid
  role        String   @default("MEMBER")
  createdAt   DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@map("community_members")
}

model CommunityMessage {
  id             String    @id @default(uuid()) @db.Uuid
  communityId    String    @db.Uuid
  tenantId       String    @db.Uuid
  authorId       String    @db.Uuid
  body           String
  editedAt       DateTime?
  deletedAt      DateTime?
  deletedById    String?   @db.Uuid
  deletedByAdmin Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User      @relation("CommunityMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  deletedBy User?     @relation("CommunityMessageDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([communityId, createdAt])
  @@index([authorId, createdAt])
  @@index([tenantId, createdAt])
  @@map("community_messages")
}

model PrivateConversation {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  firstUserId  String   @db.Uuid
  secondUserId String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstUser  User             @relation("PrivateConversationFirstUser", fields: [firstUserId], references: [id], onDelete: Cascade)
  secondUser User             @relation("PrivateConversationSecondUser", fields: [secondUserId], references: [id], onDelete: Cascade)
  messages   PrivateMessage[]

  @@unique([firstUserId, secondUserId])
  @@index([tenantId, updatedAt])
  @@index([firstUserId, updatedAt])
  @@index([secondUserId, updatedAt])
  @@map("private_conversations")
}

model PrivateMessage {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @db.Uuid
  tenantId       String    @db.Uuid
  senderId       String    @db.Uuid
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation PrivateConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender       User                @relation("PrivateMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([tenantId, createdAt])
  @@map("private_messages")
}

model Opportunity {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @db.Uuid
  ownerId      String            @db.Uuid
  visibility   ContentVisibility @default(PUBLIC)
  title        String
  company      String
  category     String?
  city         String?
  salaryLabel  String?
  description  String?
  contactEmail String?
  contactPhone String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner        User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  applications OpportunityApplication[]

  @@index([visibility, createdAt])
  @@index([tenantId, createdAt])
  @@index([ownerId, createdAt])
  @@map("opportunities")
}

model OpportunityApplication {
  id            String   @id @default(uuid()) @db.Uuid
  opportunityId String   @db.Uuid
  tenantId      String   @db.Uuid
  userId        String   @db.Uuid
  message       String?
  resumeUrl     String?
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, userId])
  @@index([userId])
  @@map("opportunity_applications")
}

model Benefit {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @db.Uuid
  ownerId         String            @db.Uuid
  visibility      ContentVisibility @default(PUBLIC)
  title           String
  partner         String
  category        String?
  city            String?
  description     String?
  pointsCost      Int               @default(0)
  redemptionCount Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  redemptions BenefitRedemption[]

  @@index([visibility, createdAt])
  @@index([tenantId, createdAt])
  @@index([ownerId, createdAt])
  @@map("benefits")
}

model BenefitRedemption {
  id        String   @id @default(uuid()) @db.Uuid
  benefitId String   @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  benefit Benefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([benefitId, userId])
  @@index([userId])
  @@map("benefit_redemptions")
}

model Event {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @db.Uuid
  ownerId     String            @db.Uuid
  visibility  ContentVisibility @default(PUBLIC)
  title       String
  organizer   String?
  mode        String?
  location    String?
  startsAt    DateTime?
  priceCents  Int               @default(0)
  capacity    Int?
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner         User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]

  @@index([visibility, startsAt])
  @@index([visibility, createdAt])
  @@index([tenantId, createdAt])
  @@index([ownerId, createdAt])
  @@map("events")
}

model EventRegistration {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_registrations")
}

model Module {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  order     Int
  courseId  String   @db.Uuid
  tenantId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, order])
  @@index([tenantId])
  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id                    String                      @id @default(uuid()) @db.Uuid
  title                 String
  order                 Int
  videoUrl              String?
  attachmentUrl         String?
  completionRequirement LessonCompletionRequirement @default(VIDEO_WATCHED)
  requiredVideoPercent  Int                         @default(80)
  progressWeight        Int                         @default(1)
  moduleId              String                      @db.Uuid
  tenantId              String                      @db.Uuid
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@unique([moduleId, order])
  @@index([tenantId])
  @@index([moduleId])
  @@map("lessons")
}

model Enrollment {
  id                  String                  @id @default(uuid()) @db.Uuid
  userId              String                  @db.Uuid
  courseId            String                  @db.Uuid
  tenantId            String                  @db.Uuid
  progressPercentage  Int                     @default(0)
  isCompleted         Boolean                 @default(false)
  paymentStatus       EnrollmentPaymentStatus @default(PENDING)
  purchaseAmountCents Int                     @default(0)
  platformFeeCents    Int                     @default(0)
  producerNetCents    Int                     @default(0)
  gatewayPaymentId    String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, courseId])
  @@unique([tenantId, gatewayPaymentId])
  @@index([tenantId])
  @@index([courseId])
  @@map("enrollments")
}

model LessonProgress {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  lessonId            String    @db.Uuid
  tenantId            String    @db.Uuid
  isWatched           Boolean   @default(false)
  videoWatchedPercent Int       @default(0)
  taskSubmittedAt     DateTime?
  evidenceUrl         String?
  completionNote      String?
  completedAt         DateTime?
  updatedAt           DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, lessonId])
  @@index([tenantId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model Certificate {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  courseId         String   @db.Uuid
  tenantId         String   @db.Uuid
  verificationCode String   @unique @default(uuid()) @db.Uuid
  issuedAt         DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, courseId])
  @@index([tenantId])
  @@map("certificates")
}

model EmailVerificationCode {
  id         String    @id @default(uuid()) @db.Uuid
  email      String
  codeHash   String
  purpose    String    @default("registration")
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([purpose])
  @@index([expiresAt])
  @@map("email_verification_codes")
}

model PlatformStaff {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  email          String       @unique
  emailHash      String?      @unique
  emailEncrypted String?
  role           PlatformRole @default(SUPPORT)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  permissions      PlatformStaffPermission[]
  assignedTickets  SupportTicket[]           @relation("AssignedSupportTickets")
  auditLogs        PlatformAuditLog[]
  requestedPayouts PlatformFeePayout[]

  @@index([role])
  @@index([emailHash])
  @@index([isActive])
  @@map("platform_staff")
}

model PlatformStaffPermission {
  id         String             @id @default(uuid()) @db.Uuid
  staffId    String             @db.Uuid
  permission PlatformPermission
  createdAt  DateTime           @default(now())

  staff PlatformStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, permission])
  @@index([permission])
  @@map("platform_staff_permissions")
}

model SupportTicket {
  id                      String                @id @default(uuid()) @db.Uuid
  tenantId                String?               @db.Uuid
  userId                  String?               @db.Uuid
  assignedToId            String?               @db.Uuid
  requesterEmailHash      String?
  requesterEmailEncrypted String?
  requesterIpEncrypted    String?
  requesterGeoEncrypted   String?
  subject                 String
  description             String?
  priority                SupportTicketPriority @default(MEDIUM)
  status                  SupportTicketStatus   @default(OPEN)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  resolvedAt              DateTime?

  tenant     Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedTo PlatformStaff? @relation("AssignedSupportTickets", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([assignedToId])
  @@index([requesterEmailHash])
  @@index([status])
  @@index([priority])
  @@map("support_tickets")
}

model PlatformAuditLog {
  id                String   @id @default(uuid()) @db.Uuid
  actorStaffId      String?  @db.Uuid
  action            String
  targetType        String
  targetId          String?
  metadata          Json?
  metadataEncrypted String?
  createdAt         DateTime @default(now())

  actorStaff PlatformStaff? @relation(fields: [actorStaffId], references: [id], onDelete: SetNull)

  @@index([actorStaffId])
  @@index([targetType])
  @@index([createdAt])
  @@map("platform_audit_logs")
}

model CourseSale {
  id               String     @id @default(uuid()) @db.Uuid
  tenantId         String     @db.Uuid
  userId           String     @db.Uuid
  courseId         String     @db.Uuid
  gateway          String
  gatewayPaymentId String     @unique
  grossAmountCents Int
  platformFeeBps   Int
  platformFeeCents Int
  producerNetCents Int
  currency         String     @default("BRL")
  status           SaleStatus @default(PAID)
  createdAt        DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([courseId])
  @@index([userId])
  @@index([status])
  @@map("course_sales")
}

model PaymentCheckout {
  id                String                  @id @default(uuid()) @db.Uuid
  gateway           String
  orderNsu          String                  @unique
  tenantId          String                  @db.Uuid
  userId            String                  @db.Uuid
  courseId          String                  @db.Uuid
  amountCents       Int
  currency          String                  @default("BRL")
  status            EnrollmentPaymentStatus @default(PENDING)
  checkoutUrl       String?
  gatewayCheckoutId String?
  transactionNsu    String?
  receiptUrl        String?
  payload           Json?
  paidAt            DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
  @@index([gateway])
  @@index([status])
  @@index([transactionNsu])
  @@map("payment_checkouts")
}

model PaymentWebhookEvent {
  id               String    @id @default(uuid()) @db.Uuid
  gateway          String
  gatewayEventId   String
  eventType        String
  tenantId         String?   @db.Uuid
  userId           String?   @db.Uuid
  courseId         String?   @db.Uuid
  gatewayPaymentId String?
  status           String    @default("RECEIVED")
  payload          Json
  payloadEncrypted String?
  errorMessage     String?
  receivedAt       DateTime  @default(now())
  processedAt      DateTime?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@unique([gateway, gatewayEventId])
  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
  @@index([gatewayPaymentId])
  @@index([status])
  @@index([receivedAt])
  @@map("payment_webhook_events")
}

model PlatformFeePayout {
  id                 String               @id @default(uuid()) @db.Uuid
  requestedByStaffId String?              @db.Uuid
  amountCents        Int
  currency           String               @default("BRL")
  pixKeyType         PixKeyType
  pixKey             String
  accountHolderName  String
  accountDocument    String?
  status             PlatformPayoutStatus @default(REQUESTED)
  requestedAt        DateTime             @default(now())
  paidAt             DateTime?
  failureReason      String?

  requestedBy PlatformStaff? @relation(fields: [requestedByStaffId], references: [id], onDelete: SetNull)

  @@index([requestedByStaffId])
  @@index([status])
  @@index([requestedAt])
  @@map("platform_fee_payouts")
}
