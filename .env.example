NODE_ENV="production"
STRICT_RUNTIME_VALIDATION="false"
PORT="3000"
APP_BASE_PATH=""
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/meetpoint?schema=public"

# JWT: prefer RS256 quando o ambiente aceitar armazenar chaves PEM. Em cPanel
# compartilhado, HS256 com segredo forte e aleatorio e a alternativa operacional
# mais simples. Sem JWT_SECRET, a aplicacao inicia em modo compatibilidade, mas
# autenticacao real deve configurar JWT_SECRET forte.
JWT_ALGORITHM="HS256"
JWT_KID="meetpoint-key-2026-01"
JWT_ISSUER="meetpoint-api"
JWT_AUDIENCE="meetpoint-clients"
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

PII_ENCRYPTION_KEY="replace-with-32-byte-base64-or-hex-key"
WEBHOOK_SECRET="replace-with-random-webhook-secret"
INFINITEPAY_HANDLE="meetpoint"
INFINITEPAY_SUCCESS_URL="https://novalab.me/meetpoint/?page=profile&payment=success"
INFINITEPAY_WEBHOOK_URL="https://meetpoint-api-y46s.onrender.com/webhooks/infinitepay"
INFINITEPAY_SUBSCRIPTION_WEBHOOK_URL="https://meetpoint-api-y46s.onrender.com/subscriptions/infinitepay-webhook"
INFINITEPAY_LINKS_ENDPOINT="https://api.checkout.infinitepay.io/links"
INFINITEPAY_PAYMENT_CHECK_ENDPOINT="https://api.checkout.infinitepay.io/payment_check"
# Link de inscrição recorrente criado no app/painel da InfinitePay.
# Use o genérico como fallback ou URLs específicas por plano/ciclo:
# INFINITEPAY_RECURRING_PF_ASSINANTE_MONTHLY_URL, INFINITEPAY_RECURRING_PJ_PARCEIRO_MONTHLY_URL, etc.
INFINITEPAY_RECURRING_CHECKOUT_URL=""
SUBSCRIPTION_WEBHOOK_SECRET="replace-with-random-subscription-webhook-secret"
SUBSCRIPTION_WEBHOOK_TOLERANCE_SECONDS="300"

CORS_ORIGIN="https://novalab.me"
CSP_CONNECT_SRC="https://novalab.me,https://meetpoint-api-y46s.onrender.com"
CHECKOUT_ALLOWED_ORIGINS="https://novalab.me"
API_PUBLIC_URL="https://meetpoint-api-y46s.onrender.com"
COOKIE_SECURE="true"
ENABLE_SWAGGER="false"
SKIP_DATABASE_CONNECT="false"

# Email transacional: obrigatório para enviar login e senha temporária das
# contas criadas pelo administrador e respostas do suporte.
SMTP_HOST="smtp.seu-provedor.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_REQUIRE_TLS="true"
SMTP_USER="no-reply@seu-dominio.com"
SMTP_PASS="senha-ou-token-do-smtp"
SMTP_FROM="MeetPoint <no-reply@seu-dominio.com>"
MEETPOINT_FRONTEND_URL="https://novalab.me/meetpoint/"

# Opcionais. REDIS_URL habilita revogacao real de JWT no logout; sem Redis, o
# servico inicia, mas tokens seguem validos ate expirarem.
REDIS_URL=""
RAG_ENABLED="false"
VECTOR_STORE_PROVIDER="noop"
VECTOR_STORE_URL=""
OPENAI_API_KEY=""
LLM_PROVIDER=""
EMBEDDING_PROVIDER=""
RAG_CACHE_TTL_SECONDS="300"
RAG_MAX_RETRIEVED_CHUNKS="8"
RAG_MIN_SCORE="0.78"
OLLAMA_URL=""
OLLAMA_ALLOWED_ORIGINS=""
OLLAMA_ALLOW_REMOTE="false"
OLLAMA_MODEL="llama3.2"
VITE_API_URL="https://SEU-BACKEND.onrender.com"
VITE_DOCUMENT_VALIDATION_ENDPOINT=""
